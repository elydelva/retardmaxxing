{
  "name": "@retardmaxxing/seed",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "seed": "./bin/seed.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./core/types": "./src/core/types.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --format=esm --outfile=bin/seed.mjs --external wrangler --external miniflare --external workerd",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:cli",
    "@retardmaxxing/database": "workspace:*",
    "@retardmaxxing/auth": "workspace:*",
    "@retardmaxxing/env": "workspace:*",
    "commander": "catalog:cli",
    "drizzle-orm": "catalog:cloudflare",
    "p-limit": "catalog:cli",
    "wrangler": "catalog:cloudflare",
    "yaml": "catalog:cli"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@retardmaxxing/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
