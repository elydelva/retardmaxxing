  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:api": "bunx moon run api:dev",
    "dev:app": "bunx moon run app:dev",
    "dev:web": "bunx moon run app:dev",
    "dev:landing": "bunx moon run landing:dev",
    "dev:mobile": "bunx moon run mobile:dev",
    "dev:storybook": "bunx moon run storybook:dev",
    "build": "bunx moon run :build",
    "test": "bunx moon run :test",
    "lint": "bunx moon run :lint",
    "lint:fix": "bunx moon run :lint-fix",
    "typecheck": "bunx moon run :typecheck",
    "format": "bunx biome format --write .",
    "ci": "bunx moon ci",
    "prepare": "bunx lefthook install",
    "seed:build": "bun run --cwd packages/seed build",
    "seed": "bun packages/seed/bin/seed.mjs",
    "seed:dev": "bun run packages/seed/src/index.ts",
    "stripe:listen": "stripe listen --forward-to http://localhost:8787/webhooks/stripe",
    "stripe:trigger": "stripe trigger",
    "test:packages": "bunx moon run :test --filter packages",
    "test:api": "bunx moon run api:test",
    "test:web": "bunx moon run app:test",
    "test:mobile": "bunx moon run mobile:test",
    "mobile:e2e": "maestro test apps/mobile/.maestro/flows/"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@moonrepo/cli": "catalog:",
    "@types/node": "catalog:",
    "lefthook": "catalog:",
    "typescript": "catalog:"
  }
}
