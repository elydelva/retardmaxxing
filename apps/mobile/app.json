{
  "expo": {
    "name": "retardmaxxing",
    "slug": "retardmaxxing",
    "version": "0.0.1",
    "scheme": "retardmaxxing",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.retardmaxxing.app",
      "supportsTablet": true,
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.retardmaxxing.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
