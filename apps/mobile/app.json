{
  "expo": {
    "name": "retardmaxxing",
    "slug": "retardmaxxing",
    "version": "0.0.1",
    "scheme": "retardmaxxing",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.retardmaxxing.app",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.retardmaxxing.app",
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      ["expo-camera", { "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera." }],
      ["expo-image-picker", { "photosPermission": "Allow $(PRODUCT_NAME) to access your photos." }],
      "expo-notifications",
      "expo-splash-screen",
      "expo-font",
      "expo-build-properties",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
