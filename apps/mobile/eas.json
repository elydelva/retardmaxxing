{
  "cli": { "version": ">= 13.0.0", "appVersionSource": "remote" },
  "build": {
    "local": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_ENV": "local" }
    },
    "staging": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_ENV": "staging" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_ENV": "production" }
    }
  }
}
